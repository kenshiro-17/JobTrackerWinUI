<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="JobTracker.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:JobTracker"
    RequestedTheme="Light">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Pastel Color Palette -->
            <Color x:Key="PastelBlue">#A8D5E5</Color>
            <Color x:Key="PastelGreen">#B5E8C3</Color>
            <Color x:Key="PastelYellow">#FFF3B8</Color>
            <Color x:Key="PastelOrange">#FFD4A8</Color>
            <Color x:Key="PastelPink">#F8C8DC</Color>
            <Color x:Key="PastelPurple">#D4C5E2</Color>
            <Color x:Key="PastelRed">#F5B7B1</Color>
            
            <!-- Status Colors -->
            <Color x:Key="StatusSaved">#A8D5E5</Color>
            <Color x:Key="StatusApplied">#B5E8C3</Color>
            <Color x:Key="StatusInterview">#FFF3B8</Color>
            <Color x:Key="StatusOffer">#C8E6C9</Color>
            <Color x:Key="StatusRejected">#F5B7B1</Color>
            
            <!-- Text Colors -->
            <Color x:Key="TextPrimary">#1A1A2E</Color>
            <Color x:Key="TextSecondary">#4A4A68</Color>
            <Color x:Key="TextMuted">#8888A0</Color>
            
            <!-- Background Colors (semi-transparent for Mica) -->
            <Color x:Key="CardBackground">#E6FFFFFF</Color>
            <Color x:Key="CardBackgroundHover">#F2FFFFFF</Color>
            
            <!-- Brushes -->
            <SolidColorBrush x:Key="PastelBlueBrush" Color="{StaticResource PastelBlue}" />
            <SolidColorBrush x:Key="PastelGreenBrush" Color="{StaticResource PastelGreen}" />
            <SolidColorBrush x:Key="PastelYellowBrush" Color="{StaticResource PastelYellow}" />
            <SolidColorBrush x:Key="PastelOrangeBrush" Color="{StaticResource PastelOrange}" />
            <SolidColorBrush x:Key="PastelPinkBrush" Color="{StaticResource PastelPink}" />
            <SolidColorBrush x:Key="PastelPurpleBrush" Color="{StaticResource PastelPurple}" />
            <SolidColorBrush x:Key="PastelRedBrush" Color="{StaticResource PastelRed}" />
            
            <SolidColorBrush x:Key="StatusSavedBrush" Color="{StaticResource StatusSaved}" />
            <SolidColorBrush x:Key="StatusAppliedBrush" Color="{StaticResource StatusApplied}" />
            <SolidColorBrush x:Key="StatusInterviewBrush" Color="{StaticResource StatusInterview}" />
            <SolidColorBrush x:Key="StatusOfferBrush" Color="{StaticResource StatusOffer}" />
            <SolidColorBrush x:Key="StatusRejectedBrush" Color="{StaticResource StatusRejected}" />
            
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
            
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}" />
            <SolidColorBrush x:Key="CardBorderBrush" Color="#20000000" />
            <SolidColorBrush x:Key="CardBorderSubtleBrush" Color="#15000000" />
            
            <!-- Typography -->
            <x:Double x:Key="FontSizeSmall">12</x:Double>
            <x:Double x:Key="FontSizeBody">14</x:Double>
            <x:Double x:Key="FontSizeMedium">16</x:Double>
            <x:Double x:Key="FontSizeLarge">20</x:Double>
            <x:Double x:Key="FontSizeTitle">28</x:Double>
            <x:Double x:Key="FontSizeHeader">36</x:Double>
            
            <!-- Stats Card Style -->
            <Style x:Key="StatsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#20000000" />
            </Style>
            
            <!-- Primary Button Style -->
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PastelBlueBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="24,12" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
            
            <!-- Accent Button Style (for Add Job) -->
            <Style x:Key="AccentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource PastelGreenBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="20,12" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
            
            <!-- Title Text Style -->
            <Style x:Key="TitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>
            
            <!-- Subtitle Text Style -->
            <Style x:Key="SubtitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeMedium}" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            </Style>
            
            <!-- Body Text Style -->
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>
            
            <!-- Caption Text Style -->
            <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="{StaticResource FontSizeSmall}" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>
            
            <!-- Stats Number Style -->
            <Style x:Key="StatsNumberStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>
            
            <!-- Job Card Style -->
            <Style x:Key="JobCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#15000000" />
            </Style>
            
            <!-- Status Badge Style -->
            <Style x:Key="StatusBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,5" />
            </Style>
            
            <!-- Search Box Style -->
            <Style x:Key="SearchBoxStyle" TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#20000000" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
